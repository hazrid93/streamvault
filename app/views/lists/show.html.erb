<div class="px-6 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-white"><%= @list.name %></h1>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_list_path(@list), class: "text-sm text-sv-accent hover:underline" if false %>
      <%= button_to "Delete list", list_path(@list), method: :delete, data: { turbo_confirm: "Delete this list?" }, class: "text-sm text-red-400 hover:underline" %>
    </div>
  </div>

  <% if @items.any? %>
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-8 gap-4">
      <% @items.each do |item| %>
        <%= render "shared/poster_card",
              item: { imdb_id: item.imdb_id, title: item.title, poster_url: item.poster_url, year: item.year, type: item.content_type },
              link_path: content_path(type: item.content_type == "show" ? "show" : "movie", imdb_id: item.imdb_id),
              variant: "grid" %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-20 text-sv-text-muted">
      <p class="text-lg">This list is empty</p>
      <p class="text-sm mt-1">Use the + button on any title to add it here.</p>
    </div>
  <% end %>
</div>
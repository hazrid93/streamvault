<div class="px-6 py-8 max-w-lg">
  <h1 class="text-2xl font-bold text-white mb-6">New list</h1>

  <% if @pending_item[:imdb_id].present? %>
    <div class="mb-4 p-3 bg-sv-accent/10 border border-sv-accent/30 rounded-lg text-sm text-sv-text">
      Creating this list will also add <span class="text-sv-accent font-medium"><%= @pending_item[:title] %></span> to it.
    </div>
  <% end %>

  <%= form_with model: @list, url: lists_path, method: :post, local: true, class: "space-y-4" do |f| %>
    <% if @list.errors.any? %>
      <div class="flash-alert">
        <% @list.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
      </div>
    <% end %>

    <%= f.label :name, class: "block text-sm text-sv-text-muted mb-1" %>
    <%= f.text_field :name, autofocus: true, placeholder: "e.g. Friday horror", class: "input-field" %>

    <%# Carry the pending item through so create can attach it. %>
    <% @pending_item.each do |k, v| %>
      <%= hidden_field_tag k, v if v.present? %>
    <% end %>

    <div class="flex gap-3">
      <%= f.submit "Create list", class: "btn-primary" %>
      <%= link_to "Cancel", lists_path, class: "btn-secondary" %>
    </div>
  <% end %>
</div>
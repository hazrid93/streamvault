<div class="px-6 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-white">My Lists</h1>
    <%= link_to "New list", new_list_path, class: "btn-primary text-sm" %>
  </div>

  <% if @lists.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @lists.each do |list| %>
        <%= link_to list_path(list), class: "block p-4 bg-sv-surface rounded-lg hover:bg-sv-surface-hover transition-colors", data: { page_loader: "link" } do %>
          <div class="flex items-center justify-between">
            <h2 class="text-lg font-bold text-white truncate"><%= list.name %></h2>
            <span class="text-sm text-sv-text-muted shrink-0 ml-2"><%= pluralize(list.list_items.size, "title") %></span>
          </div>
          <% if list.list_items.any? %>
            <div class="flex gap-1 mt-3">
              <% list.list_items.first(5).each do |item| %>
                <% if item.poster_url %>
                  <img src="<%= item.poster_url %>" alt="<%= item.title %>" class="w-10 aspect-[2/3] object-cover rounded">
                <% end %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-20 text-sv-text-muted">
      <p class="text-lg">No lists yet</p>
      <p class="text-sm mt-1">Create a list to organize your favourite titles.</p>
      <%= link_to "Create your first list", new_list_path, class: "btn-primary text-sm mt-4 inline-block" %>
    </div>
  <% end %>
</div>
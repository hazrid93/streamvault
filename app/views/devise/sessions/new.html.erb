<div class="flex items-center justify-center px-4 min-h-screen">
  <div class="w-full max-w-md">
    <%# Logo %>
    <div class="flex items-center justify-center gap-2 mb-8">
      <svg class="w-10 h-10 text-sv-accent" viewBox="0 0 24 24" fill="currentColor">
        <path d="M8 5v14l11-7z"/>
      </svg>
      <span class="text-2xl font-bold text-white tracking-tight">StreamVault</span>
    </div>

    <div class="bg-sv-surface/90 backdrop-blur-sm rounded-xl p-8 border border-sv-border">
      <h2 class="text-2xl font-bold text-white mb-6 text-center">Sign in</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="mb-4">
          <%= f.label :email, class: "block text-sm font-medium text-sv-text-muted mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input-field", placeholder: "you@example.com" %>
        </div>

        <div class="mb-4">
          <%= f.label :password, class: "block text-sm font-medium text-sv-text-muted mb-1.5" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "input-field", placeholder: "••••••••" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2 mb-6">
            <%= f.check_box :remember_me, { class: "rounded border-sv-border bg-sv-surface text-sv-accent focus:ring-sv-accent", checked: true }, "1", "0" %>
            <%= f.label :remember_me, class: "text-sm text-sv-text-muted" %>
          </div>
        <% end %>

        <%= f.submit "Sign in", class: "btn-primary w-full text-center cursor-pointer" %>
      <% end %>
    </div>

    <div class="mt-4 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>

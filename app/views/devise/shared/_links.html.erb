<%- if controller_name != 'sessions' %>
  <p class="text-sm text-sv-text-muted"><%= link_to "Already have an account? Sign in", new_session_path(resource_name), class: "text-sv-accent hover:text-sv-accent-hover" %></p>
<% end %>

<%- if devise_mapping.registerable? && signups_enabled? && controller_name != 'registrations' %>
  <p class="text-sm text-sv-text-muted"><%= link_to "Create an account", new_registration_path(resource_name), class: "text-sv-accent hover:text-sv-accent-hover" %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p class="text-sm text-sv-text-muted mt-1"><%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-sv-accent hover:text-sv-accent-hover" %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p class="text-sm text-sv-text-muted mt-1"><%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-sv-accent hover:text-sv-accent-hover" %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p class="text-sm text-sv-text-muted mt-1"><%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-sv-accent hover:text-sv-accent-hover" %></p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p class="mt-2"><%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "btn-secondary w-full" %></p>
  <% end %>
<% end %>

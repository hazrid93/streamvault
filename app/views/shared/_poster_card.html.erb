<%# locals: item, link_path, variant (optional, "carousel" default) %>
<% variant = local_assigns[:variant] || "carousel" %>
<div class="poster-card group <%= variant == "grid" ? "w-full" : "shrink-0" %>" <%= "style=\"width: 160px\"" if variant != "grid" %>>
  <%= link_to link_path, data: { page_loader: "link" } do %>
    <% if item[:poster_url] %>
      <img src="<%= item[:poster_url] %>" alt="<%= item[:title] %>" loading="lazy" class="w-full aspect-[2/3] object-cover">
    <% else %>
      <div class="w-full aspect-[2/3] bg-sv-surface flex items-center justify-center">
        <svg class="w-12 h-12 text-sv-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
      </div>
    <% end %>
    <div class="p-2">
      <h3 class="text-xs font-medium text-white truncate"><%= item[:title] %></h3>
      <p class="text-xs text-sv-text-muted mt-0.5"><%= item[:year] %></p>
    </div>
  <% end %>
  <%# Add to list (dropdown) %>
  <div class="absolute top-2 left-2 [@media(hover:hover)]:opacity-0 group-hover:opacity-100 transition-opacity"
       data-controller="list-picker"
       data-list-picker-imdb-id-value="<%= item[:imdb_id] %>"
       data-list-picker-title-value="<%= item[:title] %>"
       data-list-picker-poster-url-value="<%= item[:poster_url] %>"
       data-list-picker-year-value="<%= item[:year] %>"
       data-list-picker-content-type-value="<%= item[:type] == 'show' ? 'show' : 'movie' %>">
    <button type="button" data-action="click->list-picker#toggle"
            class="w-7 h-7 bg-black/60 rounded-full flex items-center justify-center text-white hover:bg-sv-accent transition-colors"
            title="Add to list">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
    </button>
    <div data-list-picker-target="menu"
         class="hidden absolute z-30 left-0 top-9 bg-black/90 border border-white/20 rounded-lg overflow-hidden min-w-[10rem]">
      <div data-list-picker-target="spinner" class="hidden px-3 py-2 text-xs text-sv-text-muted">Loading…</div>
      <div data-list-picker-target="list" class="max-h-48 overflow-y-auto"></div>
      <%= link_to "+ New list", new_list_path(imdb_id: item[:imdb_id], title: item[:title], poster_url: item[:poster_url], year: item[:year], content_type: item[:type] == 'show' ? 'show' : 'movie'),
            class: "block px-3 py-1.5 text-xs text-sv-accent hover:bg-sv-accent/20 border-t border-white/10" %>
    </div>
  </div>
</div>
<div class="player-container" data-controller="video-player"
     data-video-player-streaming-url-value="<%= @streaming_url %>"
     data-video-player-direct-url-value="<%= @direct_url %>"
     data-video-player-filename-value="<%= @filename %>"
     data-video-player-imdb-id-value="<%= @imdb_id %>"
     data-video-player-type-value="<%= @type %>"
     data-video-player-season-value="<%= @season %>"
     data-video-player-episode-value="<%= @episode %>"
     data-video-player-resume-at-value="<%= @resume_at %>"
     data-video-player-start-seconds-value="<%= @resume_at.present? ? @resume_at : 0 %>"
     data-video-player-duration-value="<%= @duration || 0 %>"
     data-video-player-title-value="<%= @title %>"
     data-video-player-poster-url-value="<%= @poster_url %>"
     data-video-player-default-language-value="<%= @default_language %>"
     data-video-player-preferred-languages-value="<%= @preferred_languages.to_json %>"
     data-video-player-tracks-url-value="<%= transcode_tracks_path %>"
     data-video-player-subtitles-url-value="<%= transcode_subtitles_path %>"
     data-video-player-progress-url-value="<%= progress_streaming_path("play") %>"
     data-video-player-resume-url-value="<%= resume_streaming_index_path %>">

  <%# Back button %>
  <div class="absolute top-4 left-4 z-50 opacity-100 transition-opacity duration-500" data-video-player-target="backButton"
       style="top: calc(env(safe-area-inset-top, 0px) + 1rem); left: calc(env(safe-area-inset-left, 0px) + 1rem);">
    <%= link_to content_path(type: @type, imdb_id: @imdb_id, season: @season),
          class: "flex items-center gap-2 px-3 py-2 bg-black/60 rounded-lg text-white hover:bg-black/80 transition-colors",
          data: { action: "click->video-player#navigateBack" } do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <span class="text-sm"><%= @title %></span>
    <% end %>
  </div>

  <%# Source info (top right, auto-hides) %>
  <div data-video-player-target="sourceInfo" class="hidden absolute top-4 right-4 z-10 max-w-lg opacity-100 transition-opacity duration-500"
       style="top: calc(env(safe-area-inset-top, 0px) + 1rem); right: calc(env(safe-area-inset-right, 0px) + 1rem);">
    <button data-action="click->video-player#toggleSourceInfo" data-video-player-target="sourceToggle" class="px-2 py-1 bg-black/60 rounded text-xs text-sv-text-muted hover:text-white transition-colors">
      Stream info
    </button>
    <div data-video-player-target="sourceDetails" class="hidden mt-2 p-3 bg-black/80 rounded-lg text-xs text-sv-text-muted space-y-1 break-all">
      <p><span class="text-sv-text">Source:</span> <span data-video-player-target="sourceUrl"></span></p>
      <p><span class="text-sv-text">File:</span> <span data-video-player-target="sourceFilename"></span></p>
    </div>
  </div>

  <%# Video element — no native controls, custom UI below %>
  <video data-video-player-target="video" id="stream-player"
         autoplay playsinline
         class="w-full h-full"
         style="object-fit: contain; background: #000;">
  </video>

  <div data-video-player-target="subtitleOverlay"
       class="hidden pointer-events-none absolute left-1/2 z-20 max-w-3xl -translate-x-1/2 px-4 py-2 rounded-lg bg-black/60 text-center text-lg font-semibold text-white"
       style="bottom: 6.5rem; white-space: pre-line; text-shadow: 0 2px 8px rgba(0,0,0,0.95);"></div>

  <%# Initial playback overlay (hidden once media actually starts playing) %>
  <div data-video-player-target="startupOverlay"
       class="absolute inset-0 z-30 flex items-center justify-center bg-black/80 transition-opacity duration-200"
       role="status"
       aria-live="polite"
       aria-hidden="false">
    <div class="flex flex-col items-center gap-3 px-5 py-4 rounded-lg bg-sv-surface border border-sv-border shadow-xl">
      <div class="w-12 h-12 border-4 border-white/20 border-t-indigo-500 rounded-full animate-spin"></div>
      <span class="text-white text-sm font-medium">Starting playback</span>
      <span class="text-sv-text-muted text-xs">Preparing stream...</span>
    </div>
  </div>

  <%# Custom controls bar %>
  <div data-video-player-target="controls"
       class="absolute bottom-0 left-0 right-0 z-10 bg-gradient-to-t from-black/90 via-black/50 to-transparent pt-16 pb-3 px-4 opacity-100 transition-opacity duration-500"
       style="padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 0.75rem); padding-left: calc(env(safe-area-inset-left, 0px) + 1rem); padding-right: calc(env(safe-area-inset-right, 0px) + 1rem);">

    <%# Seek bar %>
    <div data-video-player-target="seekBar"
         data-action="click->video-player#seek mousedown->video-player#startSeekDrag mouseup->video-player#stopSeekDrag mouseleave->video-player#stopSeekDrag touchstart->video-player#startSeekDrag touchend->video-player#stopSeekDrag"
         class="group relative h-1.5 bg-white/20 rounded-full cursor-pointer mb-3 hover:h-2.5 transition-all">
      <div data-video-player-target="seekBuffered" class="absolute inset-y-0 left-0 bg-white/30 rounded-full" style="width: 0%"></div>
      <div data-video-player-target="seekFilled" class="absolute inset-y-0 left-0 bg-indigo-500 rounded-full" style="width: 0%"></div>
      <div data-video-player-target="seekHandle" class="absolute w-3 h-3 bg-white rounded-full shadow opacity-0 group-hover:opacity-100 transition-opacity" style="left: 0%; top: 50%; transform: translate(-50%, -50%)"></div>
    </div>

    <%# Controls row %>
    <div class="flex items-center gap-3 text-white text-sm">
      <%# Play/pause %>
      <button data-action="click->video-player#togglePlay" data-video-player-target="playButton" class="hover:text-indigo-400 transition-colors">
        <svg data-video-player-target="playIcon" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg data-video-player-target="pauseIcon" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
      </button>

      <%# Time display %>
      <span data-video-player-target="currentTime" class="tabular-nums"><%= player_time(@resume_at) %></span>
      <span class="text-white/40">/</span>
      <span data-video-player-target="durationDisplay" class="text-white/60 tabular-nums"><%= @duration.to_f.positive? ? player_time(@duration) : "--:--" %></span>

      <div class="flex-1"></div>

      <%# Volume %>
      <button data-action="click->video-player#toggleMute" class="hover:text-indigo-400 transition-colors">
        <svg data-video-player-target="volumeIcon" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/></svg>
        <svg data-video-player-target="muteIcon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
      </button>

      <%# Audio tracks %>
      <div data-video-player-target="audioControls" class="hidden relative">
        <button type="button"
                data-action="click->video-player#toggleAudioMenu"
                class="px-2 py-1 bg-black/60 rounded text-xs text-sv-text-muted hover:text-white transition-colors">
          <span data-video-player-target="audioButtonLabel">Audio</span>
        </button>
        <div data-video-player-target="audioMenu"
             class="hidden absolute z-20 p-2 bg-black/80 rounded-lg text-xs text-sv-text-muted space-y-1 border border-white/20"
             style="right: 0; bottom: 2rem; min-width: 14rem; max-height: 14rem; overflow-y: auto;">
          <div data-video-player-target="audioOptions"></div>
        </div>
      </div>

      <%# Subtitle tracks %>
      <div data-video-player-target="subtitleControls" class="hidden relative">
        <button type="button"
                data-action="click->video-player#toggleSubtitleMenu"
                class="px-2 py-1 bg-black/60 rounded text-xs text-sv-text-muted hover:text-white transition-colors">
          <span data-video-player-target="subtitleButtonLabel">CC</span>
        </button>
        <div data-video-player-target="subtitleMenu"
             class="hidden absolute z-20 p-2 bg-black/80 rounded-lg text-xs text-sv-text-muted space-y-1 border border-white/20"
             style="right: 0; bottom: 2rem; min-width: 14rem; max-height: 14rem; overflow-y: auto;">
          <div data-video-player-target="subtitleOptions"></div>
        </div>
      </div>

      <%# Fullscreen %>
      <button data-action="click->video-player#toggleFullscreen" class="hover:text-indigo-400 transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
      </button>
    </div>
  </div>

  <%# Loading overlay (shown while ffmpeg restarts after a seek, subtitles catch up, or the stream buffers). bg-black/80 so the spinner is visible — with MSE, when the buffer runs dry Chrome shows black, not a frozen frame, so a transparent overlay would be invisible. %>
  <div data-video-player-target="seekingOverlay" class="hidden absolute inset-0 flex items-center justify-center bg-black/80 z-20">
    <div class="flex flex-col items-center gap-4">
      <div class="w-14 h-14 border-4 border-white/20 border-t-indigo-500 rounded-full animate-spin"></div>
      <span data-video-player-target="seekingOverlayMessage" class="text-white text-sm font-medium" style="text-shadow: 0 2px 8px rgba(0,0,0,0.95);">Seeking...</span>
    </div>
  </div>

</div>

<div class="player-container" data-controller="video-player"
     data-video-player-streaming-url-value="<%= @streaming_url %>"
     data-video-player-filename-value="<%= @filename %>"
     data-video-player-imdb-id-value="<%= @imdb_id %>"
     data-video-player-type-value="<%= @type %>"
     data-video-player-season-value="<%= @season %>"
     data-video-player-episode-value="<%= @episode %>"
     data-video-player-resume-at-value="<%= @resume_at %>"
     data-video-player-start-seconds-value="<%= @resume_at.present? ? @resume_at : 0 %>"
     data-video-player-duration-value="<%= @duration || 0 %>"
     data-video-player-title-value="<%= @title %>"
     data-video-player-poster-url-value="<%= @poster_url %>"
     data-video-player-progress-url-value="<%= progress_streaming_path("play") %>">

  <%# Back button (auto-hides) %>
  <div class="absolute top-4 left-4 z-10 opacity-100 transition-opacity duration-500" data-video-player-target="backButton">
    <%= link_to content_path(type: @type, imdb_id: @imdb_id, season: @season), class: "flex items-center gap-2 px-3 py-2 bg-black/60 rounded-lg text-white hover:bg-black/80 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <span class="text-sm"><%= @title %></span>
    <% end %>
  </div>

  <%# Source info (top right, auto-hides) %>
  <div data-video-player-target="sourceInfo" class="hidden absolute top-4 right-4 z-10 max-w-lg opacity-100 transition-opacity duration-500">
    <button data-action="click->video-player#toggleSourceInfo" data-video-player-target="sourceToggle" class="px-2 py-1 bg-black/60 rounded text-xs text-sv-text-muted hover:text-white transition-colors">
      Stream info
    </button>
    <div data-video-player-target="sourceDetails" class="hidden mt-2 p-3 bg-black/80 rounded-lg text-xs text-sv-text-muted space-y-1 break-all">
      <p><span class="text-sv-text">Source:</span> <span data-video-player-target="sourceUrl"></span></p>
      <p><span class="text-sv-text">File:</span> <span data-video-player-target="sourceFilename"></span></p>
    </div>
  </div>

  <%# Video element — no native controls, custom UI below %>
  <video data-video-player-target="video" id="stream-player"
         autoplay playsinline
         src="<%= @streaming_url %>"
         class="w-full h-full"
         style="object-fit: contain;">
  </video>

  <%# Initial playback overlay (hidden once media actually starts playing) %>
  <div data-playback-startup-overlay
       class="absolute inset-0 z-30 flex items-center justify-center bg-black/80 transition-opacity duration-200"
       role="status"
       aria-live="polite"
       aria-hidden="false">
    <div class="flex flex-col items-center gap-3 px-5 py-4 rounded-lg bg-sv-surface border border-sv-border shadow-xl">
      <div class="w-12 h-12 border-4 border-white/20 border-t-indigo-500 rounded-full animate-spin"></div>
      <span class="text-white text-sm font-medium">Starting playback</span>
      <span class="text-sv-text-muted text-xs">Preparing stream...</span>
    </div>
  </div>

  <%# Custom controls bar %>
  <div data-video-player-target="controls"
       class="absolute bottom-0 left-0 right-0 z-10 bg-gradient-to-t from-black/90 via-black/50 to-transparent pt-16 pb-3 px-4 opacity-100 transition-opacity duration-500">

    <%# Seek bar %>
    <div data-video-player-target="seekBar"
         data-action="click->video-player#seek mousedown->video-player#startSeekDrag mouseup->video-player#stopSeekDrag mouseleave->video-player#stopSeekDrag touchstart->video-player#startSeekDrag touchend->video-player#stopSeekDrag"
         class="group relative h-1.5 bg-white/20 rounded-full cursor-pointer mb-3 hover:h-2.5 transition-all">
      <div data-video-player-target="seekBuffered" class="absolute inset-y-0 left-0 bg-white/30 rounded-full" style="width: 0%"></div>
      <div data-video-player-target="seekFilled" class="absolute inset-y-0 left-0 bg-indigo-500 rounded-full" style="width: 0%"></div>
      <div data-video-player-target="seekHandle" class="absolute w-3 h-3 bg-white rounded-full shadow opacity-0 group-hover:opacity-100 transition-opacity" style="left: 0%; top: 50%; transform: translate(-50%, -50%)"></div>
    </div>

    <%# Controls row %>
    <div class="flex items-center gap-3 text-white text-sm">
      <%# Play/pause %>
      <button data-action="click->video-player#togglePlay" data-video-player-target="playButton" class="hover:text-indigo-400 transition-colors">
        <svg data-video-player-target="playIcon" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg data-video-player-target="pauseIcon" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
      </button>

      <%# Time display %>
      <span data-video-player-target="currentTime" class="tabular-nums"><%= player_time(@resume_at) %></span>
      <span class="text-white/40">/</span>
      <span data-video-player-target="durationDisplay" class="text-white/60 tabular-nums"><%= @duration.to_f.positive? ? player_time(@duration) : "--:--" %></span>

      <div class="flex-1"></div>

      <%# Volume %>
      <button data-action="click->video-player#toggleMute" class="hover:text-indigo-400 transition-colors">
        <svg data-video-player-target="volumeIcon" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/></svg>
        <svg data-video-player-target="muteIcon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
      </button>

      <%# Fullscreen %>
      <button data-action="click->video-player#toggleFullscreen" class="hover:text-indigo-400 transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
      </button>
    </div>
  </div>

  <%# Seeking overlay (shown while ffmpeg restarts after a seek) %>
  <div data-video-player-target="seekingOverlay" class="hidden absolute inset-0 flex items-center justify-center bg-black/60 z-20">
    <div class="flex flex-col items-center gap-3">
      <div class="w-12 h-12 border-4 border-white/20 border-t-indigo-500 rounded-full animate-spin"></div>
      <span class="text-white/80 text-sm">Seeking…</span>
    </div>
  </div>

  <script>
    (() => {
      const script = document.currentScript
      const container = script.closest(".player-container")
      if (!container) return

      const video = container.querySelector("[data-video-player-target='video']")
      const overlay = container.querySelector("[data-playback-startup-overlay]")
      if (!video || !overlay) return

      const hide = () => {
        overlay.classList.add("opacity-0", "pointer-events-none")
        overlay.setAttribute("aria-hidden", "true")
        setTimeout(() => overlay.classList.add("hidden"), 220)
      }

      video.addEventListener("playing", hide, { once: true })
      if (!video.paused && video.currentTime > 0) hide()
      setTimeout(() => {
        if (!video.paused && video.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA) hide()
      }, 0)
    })()
  </script>

  <% if @duration.to_f >= StreamingController::MIN_KNOWN_DURATION_SECONDS %>
    <script>
      (() => {
        const script = document.currentScript
        const container = script.closest(".player-container")
        if (!container) return

        const durationSeconds = Number(container.dataset.videoPlayerDurationValue)
        if (!Number.isFinite(durationSeconds) || durationSeconds < 60) return

        const video = container.querySelector("[data-video-player-target='video']")
        const currentTime = container.querySelector("[data-video-player-target='currentTime']")
        const durationDisplay = container.querySelector("[data-video-player-target='durationDisplay']")
        const seekBar = container.querySelector("[data-video-player-target='seekBar']")
        const seekFilled = container.querySelector("[data-video-player-target='seekFilled']")
        const seekHandle = container.querySelector("[data-video-player-target='seekHandle']")
        const durationLabel = durationDisplay?.textContent?.trim()
        let suppressNextClick = false

        const currentStartSeconds = () => {
          const datasetSeconds = Number(container.dataset.videoPlayerStartSecondsValue)
          if (Number.isFinite(datasetSeconds) && datasetSeconds >= 0) return datasetSeconds

          try {
            const videoUrl = new URL(video.currentSrc || video.src, window.location.origin)
            const urlSeconds = Number(videoUrl.searchParams.get("start_seconds"))
            return Number.isFinite(urlSeconds) && urlSeconds >= 0 ? urlSeconds : 0
          } catch {
            return 0
          }
        }

        const seekPercentFromEvent = (event) => {
          if (!seekBar) return 0
          const rect = seekBar.getBoundingClientRect()
          const point = event.changedTouches?.[0] || event.touches?.[0] || event
          const percent = (point.clientX - rect.left) / rect.width
          return Math.max(0, Math.min(1, percent))
        }

        const setSeekVisuals = (percent) => {
          const boundedPercent = Math.max(0, Math.min(1, percent)) * 100
          if (seekFilled) seekFilled.style.width = `${boundedPercent}%`
          if (seekHandle) seekHandle.style.left = `${boundedPercent}%`
        }

        const performKnownDurationSeek = (percent) => {
          if (!video) return

          const targetSeconds = Math.floor(percent * durationSeconds)
          container.dataset.videoPlayerStartSecondsValue = targetSeconds.toString()

          const url = new URL(container.dataset.videoPlayerStreamingUrlValue || video.currentSrc || video.src, window.location.origin)
          if (targetSeconds > 0) {
            url.searchParams.set("start_seconds", targetSeconds)
          } else {
            url.searchParams.delete("start_seconds")
          }

          const nextSrc = `${url.pathname}${url.search}`
          container.dataset.videoPlayerStreamingUrlValue = nextSrc
          video.src = nextSrc
          video.load()
          video.play()

          if (currentTime) currentTime.textContent = formatTime(targetSeconds)
          setSeekVisuals(targetSeconds / durationSeconds)
          restoreDuration()
        }

        const stopStaleControllerSeek = (event) => {
          event.preventDefault()
          event.stopImmediatePropagation()
        }

        const formatTime = (seconds) => {
          if (!Number.isFinite(seconds) || seconds < 0) return "0:00"
          const wholeSeconds = Math.floor(seconds)
          const hours = Math.floor(wholeSeconds / 3600)
          const minutes = Math.floor((wholeSeconds % 3600) / 60)
          const restSeconds = wholeSeconds % 60
          if (hours > 0) {
            return `${hours}:${minutes.toString().padStart(2, "0")}:${restSeconds.toString().padStart(2, "0")}`
          }
          return `${minutes}:${restSeconds.toString().padStart(2, "0")}`
        }

        const restoreDuration = () => {
          if (durationDisplay && durationLabel) {
            const text = durationDisplay.textContent.trim()
            if (text === "" || text === "0:00" || text === "--:--") {
              durationDisplay.textContent = durationLabel
            }
          }

          if (!video) return
          const position = video.currentTime + currentStartSeconds()
          if (currentTime) currentTime.textContent = formatTime(position)

          const percent = Math.max(0, Math.min(100, (position / durationSeconds) * 100))
          if (seekFilled) seekFilled.style.width = `${percent}%`
          if (seekHandle) seekHandle.style.left = `${percent}%`
        }

        const restoreAfterPlaybackHandlers = () => setTimeout(restoreDuration, 0)
        restoreDuration()

        if (durationDisplay) {
          new MutationObserver(restoreAfterPlaybackHandlers).observe(durationDisplay, {
            childList: true,
            characterData: true,
            subtree: true
          })
        }

        ;["loadedmetadata", "durationchange", "timeupdate", "play", "playing", "canplay"].forEach((eventName) => {
          video?.addEventListener(eventName, restoreAfterPlaybackHandlers)
        })

        if (seekBar) {
          let dragging = false

          const onPointerMove = (event) => {
            if (!dragging) return
            event.preventDefault()
            setSeekVisuals(seekPercentFromEvent(event))
          }

          const onPointerUp = (event) => {
            if (!dragging) return
            dragging = false
            document.removeEventListener("mousemove", onPointerMove)
            document.removeEventListener("mouseup", onPointerUp)
            document.removeEventListener("touchmove", onPointerMove)
            document.removeEventListener("touchend", onPointerUp)
            stopStaleControllerSeek(event)
            suppressNextClick = true
            performKnownDurationSeek(seekPercentFromEvent(event))
            setTimeout(() => { suppressNextClick = false }, 0)
          }

          const onPointerDown = (event) => {
            dragging = true
            stopStaleControllerSeek(event)
            setSeekVisuals(seekPercentFromEvent(event))
            document.addEventListener("mousemove", onPointerMove)
            document.addEventListener("mouseup", onPointerUp)
            document.addEventListener("touchmove", onPointerMove, { passive: false })
            document.addEventListener("touchend", onPointerUp)
          }

          seekBar.addEventListener("mousedown", onPointerDown, true)
          seekBar.addEventListener("touchstart", onPointerDown, { capture: true, passive: false })
          seekBar.addEventListener("click", (event) => {
            stopStaleControllerSeek(event)
            if (suppressNextClick) return
            performKnownDurationSeek(seekPercentFromEvent(event))
          }, true)
        }
      })()
    </script>
  <% end %>

  <script>
    (() => {
      const script = document.currentScript
      const container = script.closest(".player-container")
      if (!container || container.dataset.progressFallbackAttached === "true") return
      container.dataset.progressFallbackAttached = "true"

      const video = container.querySelector("[data-video-player-target='video']")
      if (!video) return

      const progressUrl = container.dataset.videoPlayerProgressUrlValue || "/streaming/play/progress"
      let lastSavedAt = 0
      let lastSavedSeconds = -1

      const numberFrom = (value) => {
        const number = Number(value)
        return Number.isFinite(number) ? number : 0
      }

      const currentStartSeconds = () => {
        try {
          const videoUrl = new URL(video.currentSrc || video.src, window.location.origin)
          const urlSeconds = numberFrom(videoUrl.searchParams.get("start_seconds"))
          if (urlSeconds > 0) return urlSeconds
        } catch {
        }

        const datasetSeconds = numberFrom(container.dataset.videoPlayerStartSecondsValue)
        return datasetSeconds > 0 ? datasetSeconds : 0
      }

      const durationSeconds = () => {
        const duration = numberFrom(container.dataset.videoPlayerDurationValue)
        return duration >= 60 ? Math.floor(duration) : 0
      }

      const saveProgress = (force = false, keepalive = false) => {
        const progressSeconds = Math.floor(numberFrom(video.currentTime) + currentStartSeconds())
        if (progressSeconds <= 0) return

        const now = Date.now()
        if (!force && now - lastSavedAt < 5000) return
        if (!force && progressSeconds === lastSavedSeconds) return

        lastSavedAt = now
        lastSavedSeconds = progressSeconds

        const csrfToken = document.querySelector("meta[name='csrf-token']")?.content
        fetch(progressUrl, {
          method: "PATCH",
          headers: { "Content-Type": "application/json", "X-CSRF-Token": csrfToken },
          body: JSON.stringify({
            imdb_id: container.dataset.videoPlayerImdbIdValue,
            progress_seconds: progressSeconds,
            duration_seconds: durationSeconds(),
            type: container.dataset.videoPlayerTypeValue || "movie",
            season: container.dataset.videoPlayerSeasonValue || null,
            episode: container.dataset.videoPlayerEpisodeValue || null,
            title: container.dataset.videoPlayerTitleValue || null,
            poster_url: container.dataset.videoPlayerPosterUrlValue || null
          }),
          keepalive
        }).catch(() => {})
      }

      video.addEventListener("playing", () => setTimeout(() => saveProgress(true), 1000))
      video.addEventListener("timeupdate", () => saveProgress(false))
      video.addEventListener("seeked", () => saveProgress(true))
      window.addEventListener("pagehide", () => saveProgress(true, true))
      window.addEventListener("beforeunload", () => saveProgress(true, true))
      setInterval(() => {
        if (!video.paused) saveProgress(false)
      }, 5000)
    })()
  </script>
</div>

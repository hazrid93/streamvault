<div class="px-6 py-8">
  <h1 class="text-3xl font-bold text-white mb-6">Wishlist</h1>

  <%# Type filter pills %>
  <div class="flex flex-wrap gap-2 mb-4">
    <%= link_to "All", wishlist_index_path, class: "px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap #{params[:type].blank? ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
    <%= link_to "Movies", wishlist_index_path(type: :movie), class: "px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap #{params[:type] == 'movie' ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
    <%= link_to "Shows", wishlist_index_path(type: :show), class: "px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap #{params[:type] == 'show' ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
  </div>

  <%# Result count and page size %>
  <% if @entries.any? %>
    <div class="flex items-center justify-between mb-4">
      <p class="text-sm text-sv-text-muted">
        Showing <%= (@page - 1) * @per_page + 1 %>&ndash;<%= [@page * @per_page, @total].min %> of <%= @total %>
      </p>
      <div class="flex items-center gap-1">
        <% [25, 50, 100].each do |size| %>
          <% if size == @per_page %>
            <span class="px-2 py-1 rounded bg-sv-accent text-white text-xs font-medium"><%= size %></span>
          <% else %>
            <%= link_to size, wishlist_index_path(params.permit(:type).merge(per_page: size, page: 1)), class: "px-2 py-1 rounded bg-sv-surface text-sv-text-muted hover:text-white text-xs transition-colors" %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @entries.any? %>
    <div class="grid gap-4" style="grid-template-columns: repeat(auto-fill, 160px)">
      <% @entries.each do |entry| %>
        <div class="poster-card group shrink-0" style="width: 160px">
          <%= link_to content_path(type: entry.content_type, imdb_id: entry.imdb_id) do %>
            <% if entry.poster_url %>
              <img src="<%= entry.poster_url %>" alt="<%= entry.title %>" loading="lazy" class="w-full aspect-[2/3] object-cover">
            <% else %>
              <div class="w-full aspect-[2/3] bg-sv-surface flex items-center justify-center">
                <svg class="w-12 h-12 text-sv-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
              </div>
            <% end %>
            <div class="p-2">
              <h3 class="text-xs font-medium text-white truncate"><%= entry.title %></h3>
              <p class="text-xs text-sv-text-muted mt-0.5"><%= entry.year %></p>
            </div>
          <% end %>
          <div class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1">
            <%= button_to move_to_library_wishlist_path(entry), class: "w-7 h-7 bg-black/60 rounded-full flex items-center justify-center text-white hover:bg-sv-accent" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            <% end %>
            <%= button_to wishlist_path(entry), method: :delete, class: "w-7 h-7 bg-black/60 rounded-full flex items-center justify-center text-white hover:bg-red-600", data: { turbo_confirm: "Remove from wishlist?" } do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Pagination %>
    <% if @total_pages > 1 %>
      <nav class="flex items-center justify-center gap-2 mt-8">
        <% if @page > 1 %>
          <%= link_to "&larr; Previous".html_safe, wishlist_index_path(params.permit(:type).merge(page: @page - 1, per_page: @per_page)), class: "px-3 py-2 rounded-lg bg-sv-surface text-sv-text hover:bg-sv-surface-hover transition-colors text-sm" %>
        <% end %>
        <% visible = [] %>
        <% visible << 1 unless @total_pages <= 1 %>
        <% ([@page - 2, 2].max..[@page + 2, @total_pages - 1].min).each { |p| visible << p } %>
        <% visible << @total_pages if @total_pages > 1 %>
        <% prev_p = 0 %>
        <% visible.uniq.sort.each do |p| %>
          <% if p - prev_p > 1 %><span class="px-2 text-sv-text-muted">&hellip;</span><% end %>
          <% if p == @page %>
            <span class="px-3 py-2 rounded-lg bg-sv-accent text-white text-sm font-medium"><%= p %></span>
          <% else %>
            <%= link_to p, wishlist_index_path(params.permit(:type).merge(page: p, per_page: @per_page)), class: "px-3 py-2 rounded-lg bg-sv-surface text-sv-text hover:bg-sv-surface-hover transition-colors text-sm" %>
          <% end %>
          <% prev_p = p %>
        <% end %>
        <% if @page < @total_pages %>
          <%= link_to "Next &rarr;".html_safe, wishlist_index_path(params.permit(:type).merge(page: @page + 1, per_page: @per_page)), class: "px-3 py-2 rounded-lg bg-sv-surface text-sv-text hover:bg-sv-surface-hover transition-colors text-sm" %>
        <% end %>
      </nav>
    <% end %>
  <% else %>
    <div class="text-center py-16">
      <svg class="w-16 h-16 text-sv-text-muted mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      <p class="text-sv-text-muted mb-4">Your wishlist is empty.</p>
      <%= link_to "Search for content", search_index_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>

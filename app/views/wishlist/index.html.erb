<div class="px-6 py-8">
  <h1 class="text-3xl font-bold text-white mb-6">Wishlist</h1>

  <% if @entries.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
      <% @entries.each do |entry| %>
        <div class="poster-card group">
          <%= link_to content_path(type: entry.content_type, imdb_id: entry.imdb_id) do %>
            <% if entry.poster_url %>
              <img src="<%= entry.poster_url %>" alt="<%= entry.title %>" loading="lazy">
            <% else %>
              <div class="aspect-[2/3] bg-sv-surface flex items-center justify-center">
                <svg class="w-12 h-12 text-sv-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
              </div>
            <% end %>
            <div class="p-3">
              <h3 class="text-sm font-medium text-white truncate"><%= entry.title %></h3>
              <p class="text-xs text-sv-text-muted mt-0.5"><%= entry.year %></p>
            </div>
          <% end %>
          <div class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1">
            <%= button_to move_to_library_wishlist_path(entry), class: "w-7 h-7 bg-black/60 rounded-full flex items-center justify-center text-white hover:bg-sv-accent" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            <% end %>
            <%= button_to wishlist_path(entry), method: :delete, class: "w-7 h-7 bg-black/60 rounded-full flex items-center justify-center text-white hover:bg-red-600", data: { turbo_confirm: "Remove from wishlist?" } do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <svg class="w-16 h-16 text-sv-text-muted mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      <p class="text-sv-text-muted mb-4">Your wishlist is empty.</p>
      <%= link_to "Search for content", search_index_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>

<div class="px-6 py-8">
  <% if @metadata %>
    <%# Hero section %>
    <div class="flex flex-col md:flex-row gap-8">
      <% if @metadata[:poster_url] %>
        <img src="<%= @metadata[:poster_url] %>" alt="<%= @metadata[:title] %>" class="w-48 rounded-lg shadow-lg shrink-0">
      <% end %>
      <div>
        <h1 class="text-3xl font-bold text-white"><%= @metadata[:title] %></h1>
        <p class="text-sv-text-muted mt-1">
          <%= @metadata[:year] %>
          <% if @metadata[:rated] %> · <%= @metadata[:rated] %><% end %>
          <% if @metadata[:runtime] %> · <%= @metadata[:runtime] %><% end %>
          <% if @metadata[:genre] %> · <%= @metadata[:genre] %><% end %>
        </p>
        <% if @metadata[:imdb_rating] %>
          <p class="text-sv-warning mt-1">⭐ <%= @metadata[:imdb_rating] %>/10</p>
        <% end %>
        <% if @metadata[:plot] %>
          <p class="text-sv-text mt-4"><%= @metadata[:plot] %></p>
        <% end %>
        <% if @metadata[:actors] %>
          <p class="text-sv-text-muted mt-2 text-sm"><span class="text-sv-text">Cast:</span> <%= @metadata[:actors] %></p>
        <% end %>

        <div class="flex gap-3 mt-6">
          <% unless @in_library %>
            <%= button_to "Add to Library", library_index_path, params: { library_entry: { content_type: @type, imdb_id: @imdb_id, title: @metadata[:title], poster_url: @metadata[:poster_url], year: @metadata[:year]&.to_i } }, class: "btn-primary" %>
          <% end %>
          <% unless @in_wishlist %>
            <%= button_to "Add to Wishlist", wishlist_index_path, params: { wishlist_entry: { content_type: @type, imdb_id: @imdb_id, title: @metadata[:title], poster_url: @metadata[:poster_url], year: @metadata[:year]&.to_i } }, class: "btn-secondary" %>
          <% end %>
        </div>
      </div>
    </div>

    <%# Streams %>
    <% if @streams.present? %>
      <h2 class="text-xl font-bold text-white mt-8 mb-4">Available Streams</h2>
      <div class="space-y-2">
        <% @streams.sort_by { |s| -(s[:seeders] || 0) }.each do |stream| %>
          <div class="flex items-center justify-between p-3 bg-sv-surface rounded-lg">
            <div>
              <span class="badge badge-accent"><%= stream[:quality] %></span>
              <span class="text-sm text-white ml-2 truncate"><%= stream[:title] || stream[:name] %></span>
              <span class="text-xs text-sv-text-muted ml-2"><%= stream[:size] %></span>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-xs text-sv-text-muted">👤 <%= stream[:seeders] || 0 %></span>
              <%= button_to "Watch", streaming_index_path, params: { imdb_id: @imdb_id, type: @type, season: params[:season], episode: params[:episode], title: @metadata[:title] }, class: "btn-primary text-sm", data: { turbo: false } %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="mt-8 p-4 bg-sv-surface rounded-lg border border-sv-border text-center">
        <p class="text-sv-text-muted">No streams available for this selection.</p>
        <% unless current_user.has_realdebrid_key? %>
          <p class="text-sv-text-muted mt-1">Add your RealDebrid API key in <%= link_to "Settings", settings_path, class: "text-sv-accent" %> to enable streaming.</p>
        <% end %>
      </div>
    <% end %>

    <%# Episodes for shows %>
    <% if @type == "show" && @metadata[:episodes].present? %>
      <h2 class="text-xl font-bold text-white mt-8 mb-4">Episodes</h2>

      <%# Season tabs %>
      <% seasons = @metadata[:episodes].map { |e| e[:season] }.uniq.sort %>
      <div class="flex gap-2 mb-4 overflow-x-auto">
        <% seasons.each do |s| %>
          <%= link_to content_path(type: @type, imdb_id: @imdb_id, season: s), class: "px-3 py-1.5 rounded-full text-sm font-medium #{@selected_season == s ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" do %>
            Season <%= s %>
          <% end %>
        <% end %>
      </div>

      <%# Episode list %>
      <div class="space-y-2">
        <% @metadata[:episodes].select { |e| e[:season] == @selected_season }.each do |ep| %>
          <% progress = @episode_progress&.dig([ep[:season], ep[:episode]]) %>
          <div class="flex items-center gap-4 p-3 bg-sv-surface rounded-lg hover:bg-sv-surface-hover transition-colors">
            <div class="w-8 text-center text-sv-text-muted text-sm font-medium"><%= ep[:episode] %></div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-medium text-white truncate"><%= ep[:title] || "Episode #{ep[:episode]}" %></h3>
              <% if ep[:released] %>
                <p class="text-xs text-sv-text-muted"><%= ep[:released] %></p>
              <% end %>
              <% if progress %>
                <div class="mt-1 h-1 bg-sv-border rounded-full overflow-hidden">
                  <div class="h-full bg-sv-accent rounded-full" style="width: <%= progress.progress_percentage %>%"></div>
                </div>
              <% end %>
            </div>
            <%= button_to "Play", streaming_index_path, params: { imdb_id: @imdb_id, type: "show", season: ep[:season], episode: ep[:episode], title: "#{@metadata[:title]} S#{ep[:season]}E#{ep[:episode]}" }, class: "btn-primary text-xs px-3 py-1", data: { turbo: false } %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p class="text-sv-text-muted">Content not found.</p>
  <% end %>
</div>

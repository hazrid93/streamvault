<%# Back link — link to a known internal route instead of the raw
   Referer header, which is attacker-controlled and would otherwise
   render an off-site (open-redirect / phishing) link. %>
<% if request.referer&.include?("/search") %>
  <div class="px-6 pt-4">
    <%= link_to "← Back to search results", search_index_path, class: "text-sm text-sv-accent hover:underline" %>
  </div>
<% elsif request.referer&.include?("/library") %>
  <div class="px-6 pt-4">
    <%= link_to "← Back to library", library_index_path, class: "text-sm text-sv-accent hover:underline" %>
  </div>
<% elsif request.referer&.include?("/wishlist") %>
  <div class="px-6 pt-4">
    <%= link_to "← Back to wishlist", wishlist_index_path, class: "text-sm text-sv-accent hover:underline" %>
  </div>
<% elsif request.referer&.include?("/watch_history") %>
  <div class="px-6 pt-4">
    <%= link_to "← Back to history", watch_history_index_path, class: "text-sm text-sv-accent hover:underline" %>
  </div>
<% end %>

<div class="px-6 py-8">
  <% if @metadata %>
    <%# Hero section %>
    <div class="flex flex-col md:flex-row gap-8">
      <% if @metadata[:poster_url] %>
        <div class="shrink-0">
          <img src="<%= @metadata[:poster_url] %>" alt="<%= @metadata[:title] %>" class="w-48 rounded-lg shadow-lg">
          <% if @progress && @progress > 0 %>
            <div class="mt-2">
              <div class="h-1 bg-sv-border rounded-full overflow-hidden">
                <div class="h-full bg-sv-accent rounded-full" style="width: <%= @progress %>%"></div>
              </div>
              <p class="text-xs text-sv-text-muted mt-1"><%= @progress %>% watched</p>
            </div>
          <% end %>
        </div>
      <% end %>
      <div>
        <h1 class="text-3xl font-bold text-white"><%= @metadata[:title] %></h1>
        <p class="text-sv-text-muted mt-1">
          <%= @metadata[:year] %>
          <% if @type != "show" && @metadata[:runtime] %> · <%= @metadata[:runtime] %><% end %>
          <% if @metadata[:genre] %> · <%= @metadata[:genre] %><% end %>
        </p>
        <div class="flex items-center gap-3 mt-1 flex-wrap">
          <% if @metadata[:rated] %>
            <span class="px-2 py-0.5 border border-sv-text-muted rounded text-xs text-sv-text-muted font-medium"><%= @metadata[:rated] %></span>
          <% end %>
          <% if @metadata[:imdb_rating] %>
            <span class="text-sv-warning text-sm font-medium">⭐ <%= @metadata[:imdb_rating] %>/10</span>
          <% end %>
          <% if @metadata[:rt_rating] %>
            <span class="text-sm font-medium" style="color: #fa320a;">🍅 <%= @metadata[:rt_rating] %></span>
          <% end %>
          <% if @metadata[:metascore] %>
            <span class="px-1.5 py-0.5 text-xs font-bold rounded" style="background: #00cf4a; color: #000;">Metascore <%= @metadata[:metascore] %></span>
          <% end %>
        </div>
        <% if @metadata[:plot] %>
          <p class="text-sv-text mt-4"><%= @metadata[:plot] %></p>
        <% end %>
        <% if @metadata[:actors] %>
          <p class="text-sv-text-muted mt-2 text-sm"><span class="text-sv-text">Cast:</span>
            <% @metadata[:actors].split(",").map(&:strip).reject(&:blank?).each_with_index do |actor, idx| %>
              <%= ", " if idx > 0 %><%= link_to actor, person_path(name: actor), class: "text-sv-text-muted hover:text-sv-accent hover:underline transition-colors", data: { page_loader: "link" } %>
            <% end %>
          </p>
        <% end %>

        <div class="flex gap-3 mt-6">
          <%# Library %>
          <% lib_params = { library_entry: { content_type: @type, imdb_id: @imdb_id, title: @metadata[:title], poster_url: @metadata[:poster_url], year: @metadata[:year]&.to_i } }.to_query %>
          <button type="button"
                  class="w-8 h-8 bg-sv-surface rounded-lg hover:bg-sv-surface-hover flex items-center justify-center transition-colors cursor-pointer <%= @in_library ? 'text-sv-accent' : 'text-sv-text-muted hover:text-sv-accent' %>"
                  data-controller="toggle-button"
                  data-action="click->toggle-button#toggle"
                  data-toggle-button-kind-value="library"
                  data-toggle-button-add-url-value="<%= library_index_path %>"
                  data-toggle-button-destroy-url-value="<%= @in_library && @library_entry ? library_path(@library_entry) : '' %>"
                  data-toggle-button-add-title-value="Add to Library"
                  data-toggle-button-added-title-value="In your library — click to remove"
                  data-toggle-button-added-value="<%= @in_library %>"
                  data-toggle-button-status-url-value="<%= content_status_path(type: @type, imdb_id: @imdb_id) %>"
                  data-toggle-button-params="<%= lib_params %>"
                  title="<%= @in_library ? 'In your library — click to remove' : 'Add to Library' %>">
            <% if @in_library %>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <% else %>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            <% end %>
          </button>

          <%# Wishlist %>
          <% wish_params = { wishlist_entry: { content_type: @type, imdb_id: @imdb_id, title: @metadata[:title], poster_url: @metadata[:poster_url], year: @metadata[:year]&.to_i } }.to_query %>
          <button type="button"
                  class="w-8 h-8 bg-sv-surface rounded-lg hover:bg-sv-surface-hover flex items-center justify-center transition-colors cursor-pointer <%= @in_wishlist ? 'text-sv-accent' : 'text-sv-text-muted hover:text-sv-accent' %>"
                  data-controller="toggle-button"
                  data-action="click->toggle-button#toggle"
                  data-toggle-button-kind-value="wishlist"
                  data-toggle-button-add-url-value="<%= wishlist_index_path %>"
                  data-toggle-button-destroy-url-value="<%= @in_wishlist && @wishlist_entry ? wishlist_path(@wishlist_entry) : '' %>"
                  data-toggle-button-add-title-value="Add to Wishlist"
                  data-toggle-button-added-title-value="In your wishlist — click to remove"
                  data-toggle-button-added-value="<%= @in_wishlist %>"
                  data-toggle-button-status-url-value="<%= content_status_path(type: @type, imdb_id: @imdb_id) %>"
                  data-toggle-button-params="<%= wish_params %>"
                  title="<%= @in_wishlist ? 'In your wishlist — click to remove' : 'Add to Wishlist' %>">
            <% if @in_wishlist %>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <% else %>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <% end %>
          </button>
        </div>
      </div>
    </div>

    <%# MOVIES: show streams directly %>
    <% if @type != "show" %>
      <% if @streams_error.present? %>
        <div class="mt-8 p-4 bg-sv-surface rounded-lg border border-sv-border text-center">
          <p class="text-sv-warning"><%= @streams_error %></p>
          <p class="text-sv-text-muted mt-1 text-sm">If this persists, the stream provider may be blocking this server's IP. Consider setting <code>TORRENTIO_PROXY</code> or <code>TORRENTIO_API_BASE_URL</code> env vars.</p>
        </div>
      <% elsif @streams.present? %>
        <h2 class="text-xl font-bold text-white mt-8 mb-4">Available Streams</h2>
        <%# Quality filter + RD-first stream sorting (client-side via stream_filter controller) %>
        <div data-controller="stream-filter">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <div class="inline-flex flex-wrap gap-1">
              <% ["all", "4K", "1080p", "720p", "480p"].each do |q| %>
                <% label = q == "all" ? "All" : q %>
                <button type="button" data-action="click->stream-filter#filter" data-quality="<%= q %>"
                      class="px-3 py-1 rounded-full text-xs font-medium transition-colors border border-sv-border text-sv-text-muted hover:text-white hover:border-sv-text-muted"><%= label %></button>
              <% end %>
            </div>
            <div class="inline-flex flex-wrap gap-1">
              <% [["seeders", "Most seeders"], ["quality", "Best quality"], ["size", "Largest size"]].each do |val, label| %>
                <button type="button" data-action="click->stream-filter#sort" data-sort="<%= val %>"
                      class="px-3 py-1 rounded-full text-xs font-medium transition-colors border border-sv-border text-sv-text-muted hover:text-white hover:border-sv-text-muted"><%= label %></button>
              <% end %>
            </div>
            <span class="text-xs text-sv-text-muted ml-auto"><span data-stream-filter-target="count"><%= @streams.size %></span> streams</span>
            <p data-stream-filter-target="empty" class="hidden w-full text-sm text-sv-text-muted">No streams match this filter.</p>
          </div>
          <div class="space-y-2">
            <% @streams.each do |stream| %>
              <% size_bytes = stream[:raw_size] || (stream[:size].to_s =~ /([\d.]+)\s*GB/i ? ($1.to_f * 1024**3).to_i : stream[:size].to_s =~ /([\d.]+)\s*MB/i ? ($1.to_f * 1024**2).to_i : 0) %>
              <div class="flex items-center justify-between gap-3 p-3 bg-sv-surface rounded-lg" data-stream-filter-target="row" data-quality="<%= stream[:quality] %>" data-size="<%= size_bytes %>" data-rd-plus="<%= stream[:rd_plus] ? 'true' : 'false' %>" data-seeders="<%= stream[:seeders] %>">
                <div class="min-w-0 flex-1 overflow-hidden">
                  <div class="flex items-center gap-1.5">
                    <% if stream[:rd_plus] %><span class="badge badge-success shrink-0">RD+</span><% end %>
                    <span class="text-sm text-white truncate"><%= stream[:title] || stream[:name] %></span>
                  </div>
                  <div class="flex items-center gap-1.5 mt-1">
                    <span class="badge badge-accent"><%= stream[:quality] %></span>
                    <% stream[:languages]&.each do |lang| %>
                      <span class="px-1.5 py-0.5 rounded text-xs font-medium bg-sv-surface-hover text-sv-text-muted"><%= lang %></span>
                    <% end %>
                    <span class="text-xs text-sv-text-muted"><%= stream[:size] %></span>
                    <% unless stream[:seeders].nil? %>
                      <span class="text-xs text-sv-text-muted" title="Seeders">👤 <%= stream[:seeders] %></span>
                    <% end %>
                  </div>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                  <%= button_to "Watch", streaming_index_path, params: { imdb_id: @imdb_id, type: @type, title: @metadata[:title], poster_url: @metadata[:poster_url], duration: @metadata[:runtime_seconds], resolve_url: stream[:resolve_url], filename: stream[:filename] }, class: "btn-primary text-sm", data: { turbo: false } %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="mt-8 p-4 bg-sv-surface rounded-lg border border-sv-border text-center">
          <p class="text-sv-text-muted">No streams available for this content.</p>
          <% unless current_user.has_realdebrid_key? %>
            <p class="text-sv-text-muted mt-1">Add your RealDebrid API key in <%= link_to "Settings", settings_path, class: "text-sv-accent" %> to enable streaming.</p>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%# SHOWS: season tabs + episode list + streams drawer %>
    <% if @type == "show" && @metadata[:episodes].present? %>
      <% seasons = @metadata[:episodes].map { |e| e[:season] }.reject { |s| s == 0 }.uniq.sort %>
      <div class="flex flex-wrap gap-2 mt-8 mb-4">
        <% seasons.each do |s| %>
          <%= link_to content_path(type: @type, imdb_id: @imdb_id, season: s), class: "px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap #{@selected_season == s ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}", data: { page_loader: "link" } do %>
            Season <%= s %>
          <% end %>
        <% end %>
      </div>

      <div class="space-y-2" data-controller="episode-picker"
           data-episode-picker-url-value="<%= episode_streams_path(type: @type, imdb_id: @imdb_id) %>"
           data-episode-picker-imdb-id-value="<%= @imdb_id %>"
           data-episode-picker-show-title-value="<%= @metadata[:title] %>">
        <% @metadata[:episodes].select { |e| e[:season] == @selected_season && e[:season] != 0 }.each do |ep| %>
          <% progress = @episode_progress&.dig([ep[:season], ep[:episode]]) %>
          <div class="bg-sv-surface rounded-lg hover:bg-sv-surface-hover transition-colors"
               data-episode-picker-target="episode">
            <button class="flex items-center gap-4 p-3 w-full text-left"
                    data-action="click->episode-picker#toggle"
                    data-season="<%= ep[:season] %>"
                    data-episode="<%= ep[:episode] %>"
                    data-title="<%= ep[:title] %>">
              <div class="w-8 text-center text-sv-text-muted text-sm font-medium shrink-0"><%= ep[:episode] %></div>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-medium text-white truncate"><%= ep[:title] || "Episode #{ep[:episode]}" %></h3>
                <p class="text-xs text-sv-text-muted">
                  <%= ep[:released] %><% if ep[:runtime] %> · <%= ep[:runtime] %><% end %>
                </p>
                <% if ep[:overview].present? %>
                  <p class="text-xs text-sv-text-muted mt-0.5 line-clamp-2"><%= ep[:overview] %></p>
                <% end %>
                <% if progress %>
                  <div class="mt-1 h-1 bg-sv-border rounded-full overflow-hidden">
                    <div class="h-full bg-sv-accent rounded-full" style="width: <%= progress.progress_percentage %>%"></div>
                  </div>
                <% end %>
              </div>
              <svg class="w-4 h-4 text-sv-text-muted shrink-0 transition-transform" data-episode-picker-target="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>

            <div data-episode-picker-target="drawer" class="hidden border-t border-sv-border">
              <div data-episode-picker-target="drawerContent" class="p-3">
                <div class="flex items-center gap-2 text-sv-text-muted text-sm">
                  <div class="w-4 h-4 border-2 border-sv-accent border-t-transparent rounded-full animate-spin"></div>
                  Loading streams...
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p class="text-sv-text-muted">Content not found.</p>
  <% end %>
</div>

<%# Similar titles (TMDB recommendations) %>
<% if @similar.present? %>
  <div class="px-4 sm:px-6 lg:px-8 pb-8 -mx-4 sm:-mx-6 lg:-mx-8">
    <section class="mb-2" data-controller="carousel">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold text-white">More Like This</h2>
        <div class="flex items-center gap-2">
          <button data-action="click->carousel#prev" data-carousel-target="prevBtn" class="w-8 h-8 rounded-full bg-sv-surface hover:bg-sv-surface-hover flex items-center justify-center text-white transition-colors invisible">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button data-action="click->carousel#next" data-carousel-target="nextBtn" class="w-8 h-8 rounded-full bg-sv-surface hover:bg-sv-surface-hover flex items-center justify-center text-white transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
      <div class="relative">
        <div data-carousel-target="track" class="flex gap-4 overflow-x-auto scrollbar-hide pb-2">
          <% @similar.each do |item| %>
            <%= render "shared/poster_card",
                  item: item,
                  link_path: content_path(type: item[:type].presence || @type, imdb_id: item[:imdb_id]) %>
          <% end %>
        </div>
      </div>
    </section>
  </div>
<% end %>

<div id="stream-resolve-loading"
     class="hidden fixed inset-0 z-50 bg-black/80 flex items-center justify-center"
     role="status"
     aria-live="polite"
     aria-hidden="true"
     data-controller="stream-loading"
     data-stream-loading-path-value="<%= streaming_index_path %>">
  <div class="flex flex-col items-center gap-3 px-5 py-4 rounded-lg bg-sv-surface border border-sv-border shadow-xl">
    <div class="w-10 h-10 border-4 border-white/20 border-t-indigo-500 rounded-full animate-spin"></div>
    <div class="text-sm font-medium text-white">Finding a working stream</div>
    <div class="text-xs text-sv-text-muted">Trying available sources...</div>
  </div>
</div>

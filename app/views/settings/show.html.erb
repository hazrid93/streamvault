<div class="px-6 py-8 max-w-2xl">
  <h1 class="text-3xl font-bold text-white mb-8">Settings</h1>

  <%= form_with model: @user, url: settings_path, method: :patch, class: "space-y-6" do |f| %>
    <% if @user.errors.any? %>
      <div class="bg-red-900/20 border border-red-800/40 rounded-lg p-4">
        <ul class="list-disc list-inside text-sm text-red-300">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-sv-surface rounded-xl p-6 border border-sv-border">
      <h2 class="text-lg font-semibold text-white mb-4">Account</h2>

      <div>
        <label class="block text-sm font-medium text-sv-text-muted mb-1.5">Email</label>
        <input type="email" value="<%= @user.email %>" class="input-field" disabled>
      </div>
    </div>

    <div class="bg-sv-surface rounded-xl p-6 border border-sv-border">
      <h2 class="text-lg font-semibold text-white mb-4">RealDebrid</h2>

      <div class="mb-4">
        <%= f.label :realdebrid_api_key, "API Key", class: "block text-sm font-medium text-sv-text-muted mb-1.5" %>
        <%= f.password_field :realdebrid_api_key, class: "input-field", placeholder: "Enter your RealDebrid API key", value: "" %>
        <p class="text-xs text-sv-text-muted mt-1">Get your API key from <a href="https://real-debrid.com/apitoken" target="_blank" class="text-sv-accent">real-debrid.com/apitoken</a></p>
      </div>

      <% if @user.has_realdebrid_key? %>
        <div class="flex items-center gap-2 text-sv-success text-sm">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          API key configured
        </div>
      <% end %>
    </div>

    <div class="bg-sv-surface rounded-xl p-6 border border-sv-border">
      <h2 class="text-lg font-semibold text-white mb-2">Preferred Languages</h2>
      <p class="text-xs text-sv-text-muted mb-4">Select at least one language. Streams without at least one of your selected languages will be filtered out.</p>

      <div class="flex flex-wrap gap-2 mb-4" data-controller="language-picker">
        <% User::STREAM_LANGUAGE_OPTIONS.each do |code, name| %>
          <% selected = Array(@user.preferred_languages).include?(code) %>
          <label class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm cursor-pointer transition-colors"
                 data-language-picker-target="pill"
                 data-code="<%= code %>"
                 data-selected="<%= selected %>"
                 style="<%= selected ? 'background-color: var(--color-sv-accent); color: white;' : 'background-color: var(--color-sv-surface-hover); color: var(--color-sv-text-muted);' %>">
            <input type="checkbox" name="user[preferred_languages][]" value="<%= code %>" <%= 'checked' if selected %> class="hidden">
            <span><%= name %></span>
          </label>
        <% end %>
      </div>
      <input type="hidden" name="user[preferred_languages][]" value="">
    </div>

    <div class="bg-sv-surface rounded-xl p-6 border border-sv-border">
      <h2 class="text-lg font-semibold text-white mb-2">Default Language</h2>
      <p class="text-xs text-sv-text-muted mb-4">Default audio language when starting a stream.</p>

      <%= f.select :default_language,
        options_for_select(
          Array(@user.preferred_languages).map { |c| [User::STREAM_LANGUAGE_OPTIONS[c], c] },
          @user.default_language
        ),
        {},
        class: "input-field w-auto"
      %>
    </div>

    <%= f.submit "Save Settings", class: "btn-primary cursor-pointer" %>
  <% end %>
</div>

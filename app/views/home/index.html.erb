<div class="px-6 py-8">
  <%# Search bar %>
  <div class="mb-8">
    <%= form_tag search_index_path, method: :get, class: "max-w-2xl", data: { turbo_frame: "_top", page_loader: "search" } do %>
      <div class="flex gap-3">
        <%= text_field_tag :q, params[:q], class: "input-field flex-1", placeholder: "Search for movies, TV shows..." %>
        <%= submit_tag "Search", class: "btn-primary cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <% unless current_user.has_realdebrid_key? %>
    <div class="mb-8 p-4 bg-sv-accent/10 border border-sv-accent/30 rounded-lg">
      <p class="text-sv-text">Welcome to StreamVault! Add your RealDebrid API key in <%= link_to "Settings", settings_path, class: "text-sv-accent font-medium hover:underline" %> to start streaming.</p>
    </div>
  <% end %>

  <%# Continue Watching (custom markup with progress bars) %>
  <% if @continue_watching.any? %>
    <section class="mb-10" data-controller="carousel">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold text-white">Continue Watching</h2>
        <div class="flex items-center gap-2">
          <button data-action="click->carousel#prev" data-carousel-target="prevBtn" class="w-8 h-8 rounded-full bg-sv-surface hover:bg-sv-surface-hover flex items-center justify-center text-white transition-colors invisible">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button data-action="click->carousel#next" data-carousel-target="nextBtn" class="w-8 h-8 rounded-full bg-sv-surface hover:bg-sv-surface-hover flex items-center justify-center text-white transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
      <div class="relative">
        <div data-carousel-target="track" class="flex gap-4 overflow-x-auto scrollbar-hide pb-2">
          <% @continue_watching.each do |item| %>
            <div class="poster-card group shrink-0" style="width: 180px">
              <%= link_to resume_streaming_index_path(type: item[:content_type] == "episode" ? "show" : "movie", show_imdb_id: item[:imdb_id], imdb_id: item[:imdb_id]), data: { page_loader: "link" } do %>
                <% if item[:poster_url] %>
                  <img src="<%= item[:poster_url] %>" alt="<%= item[:title] %>" loading="lazy" class="w-full aspect-[2/3] object-cover">
                <% else %>
                  <div class="w-full aspect-[2/3] bg-sv-surface flex items-center justify-center">
                    <svg class="w-12 h-12 text-sv-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
                  </div>
                <% end %>
                <div class="p-2">
                  <h3 class="text-xs font-medium text-white truncate"><%= item[:title] %></h3>
                  <% if item[:content_type] == "episode" %>
                    <p class="text-xs text-sv-text-muted">S<%= item[:season].to_s.rjust(2, '0') %>E<%= item[:episode].to_s.rjust(2, '0') %></p>
                  <% end %>
                </div>
                <div class="card-progress">
                  <div class="card-progress-bar" style="width: <%= item[:progress_percentage] %>%"></div>
                </div>
              <% end %>
              <div class="absolute top-2 right-2 [@media(hover:hover)]:opacity-0 group-hover:opacity-100 transition-opacity">
                <%= button_to watch_history_path(item[:history_id]), method: :delete, class: "w-6 h-6 bg-black/60 rounded-full flex items-center justify-center text-white hover:bg-red-600", title: "Remove from Continue Watching" do %>
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <%# Up Next (series) %>
  <% if @up_next.any? %>
    <section class="mb-10" data-controller="carousel">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold text-white">Up Next</h2>
        <div class="flex items-center gap-2">
          <button data-action="click->carousel#prev" data-carousel-target="prevBtn" class="w-8 h-8 rounded-full bg-sv-surface hover:bg-sv-surface-hover flex items-center justify-center text-white transition-colors invisible">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button data-action="click->carousel#next" data-carousel-target="nextBtn" class="w-8 h-8 rounded-full bg-sv-surface hover:bg-sv-surface-hover flex items-center justify-center text-white transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
      <div class="relative">
        <div data-carousel-target="track" class="flex gap-4 overflow-x-auto scrollbar-hide pb-2">
          <% @up_next.each do |item| %>
            <div class="shrink-0" style="width: 240px">
              <%= link_to content_path(type: "show", imdb_id: item[:show_imdb_id]), class: "block", data: { page_loader: "link" } do %>
                <div class="relative rounded-lg overflow-hidden bg-sv-surface">
                  <% if item[:poster_url] %>
                    <img src="<%= item[:poster_url] %>" alt="<%= item[:show_title] %>" loading="lazy" class="w-full aspect-[2/3] object-cover">
                  <% end %>
                  <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-black/90 to-transparent">
                    <p class="text-sm font-bold text-white truncate"><%= item[:show_title] %></p>
                    <p class="text-xs text-sv-text-muted">S<%= item[:season].to_s.rjust(2, '0') %>E<%= item[:episode].to_s.rjust(2, '0') %> &middot; <%= item[:episode_title] %></p>
                    <% if item[:resume] %>
                      <span class="inline-block mt-1 px-2 py-0.5 rounded text-xs bg-sv-accent/20 text-sv-accent">Resume <%= item[:progress_percentage] %>%</span>
                    <% else %>
                      <span class="inline-block mt-1 px-2 py-0.5 rounded text-xs bg-white/10 text-white">Up Next</span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <%# Recommended for You %>
  <% if @recommendations.success? %>
    <%= render "home/catalog_section",
          title: "Recommended for You",
          items: @recommendations.data %>
  <% end %>

  <%# Recently Added %>
  <%= render "home/catalog_section",
        title: "Recently Added",
        items: @recently_added.map { |e| { imdb_id: e.imdb_id, title: e.title, poster_url: e.poster_url, year: e.year, type: e.content_type } },
        view_all_path: library_index_path %>

  <%# Wishlist %>
  <%= render "home/catalog_section",
        title: "Wishlist",
        items: @wishlist_preview.map { |e| { imdb_id: e.imdb_id, title: e.title, poster_url: e.poster_url, year: e.year, type: e.content_type } },
        view_all_path: wishlist_index_path %>

  <%# Popular Movies %>
  <% if @popular.success? %>
    <%= render "home/catalog_section",
          title: "Popular Movies",
          items: @popular.data,
          type: "movie",
          browse_path: browse_path(type: "movie", catalog: "top") %>
  <% end %>

  <%# Trending Movies %>
  <% if @trending.success? %>
    <%= render "home/catalog_section",
          title: "Trending Movies",
          items: @trending.data,
          type: "movie",
          browse_path: browse_path(type: "movie", catalog: "year") %>
  <% end %>

  <%# Popular Shows %>
  <% if @popular_shows.success? %>
    <%= render "home/catalog_section",
          title: "Popular Shows",
          items: @popular_shows.data,
          type: "show",
          browse_path: browse_path(type: "show", catalog: "top") %>
  <% end %>

  <%# Trending Shows %>
  <% if @trending_shows.success? %>
    <%= render "home/catalog_section",
          title: "Trending Shows",
          items: @trending_shows.data,
          type: "show",
          browse_path: browse_path(type: "show", catalog: "year") %>
  <% end %>
</div>
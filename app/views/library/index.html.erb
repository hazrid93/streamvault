<div class="px-6 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold text-white">Library</h1>
    <%= link_to "Search for content", search_index_path, class: "btn-secondary text-sm" %>
  </div>

  <%# Filter tabs %>
  <div class="flex gap-2 mb-6 overflow-x-auto">
    <%= link_to "All", library_index_path, class: "px-3 py-1.5 rounded-full text-sm font-medium #{params[:type].blank? && params[:status].blank? ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
    <%= link_to "Movies", library_index_path(type: :movie), class: "px-3 py-1.5 rounded-full text-sm font-medium #{params[:type] == 'movie' ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
    <%= link_to "Shows", library_index_path(type: :show), class: "px-3 py-1.5 rounded-full text-sm font-medium #{params[:type] == 'show' ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
    <%= link_to "Watching", library_index_path(status: :watching), class: "px-3 py-1.5 rounded-full text-sm font-medium #{params[:status] == 'watching' ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
    <%= link_to "Finished", library_index_path(status: :finished), class: "px-3 py-1.5 rounded-full text-sm font-medium #{params[:status] == 'finished' ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
  </div>

  <% if @entries.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
      <% @entries.each do |entry| %>
        <div class="poster-card group">
          <%= link_to content_path(type: entry.content_type, imdb_id: entry.imdb_id) do %>
            <% if entry.poster_url %>
              <img src="<%= entry.poster_url %>" alt="<%= entry.title %>" loading="lazy">
            <% else %>
              <div class="aspect-[2/3] bg-sv-surface flex items-center justify-center">
                <svg class="w-12 h-12 text-sv-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
              </div>
            <% end %>
            <div class="p-3">
              <h3 class="text-sm font-medium text-white truncate"><%= entry.title %></h3>
              <p class="text-xs text-sv-text-muted mt-0.5"><%= entry.year %></p>
              <span class="badge badge-accent text-xs mt-1"><%= entry.watch_status.humanize %></span>
            </div>
          <% end %>
          <div class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <%= button_to library_path(entry), method: :delete, class: "w-7 h-7 bg-black/60 rounded-full flex items-center justify-center text-white hover:bg-red-600", data: { turbo_confirm: "Remove from library?" } do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <svg class="w-16 h-16 text-sv-text-muted mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      <p class="text-sv-text-muted mb-4">Your library is empty.</p>
      <%= link_to "Search for content", search_index_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>

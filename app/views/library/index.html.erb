<div class="px-6 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold text-white">Library</h1>
    <%= link_to search_index_path, class: "btn-secondary text-sm" do %>
      <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      Search
    <% end %>
  </div>

  <%# Filter tabs %>
  <div class="flex flex-wrap gap-2 mb-4">
    <%= link_to "All", library_index_path, class: "px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap #{params[:type].blank? && params[:status].blank? ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
    <%= link_to "Movies", library_index_path(type: :movie), class: "px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap #{params[:type] == 'movie' ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
    <%= link_to "Shows", library_index_path(type: :show), class: "px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap #{params[:type] == 'show' ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
    <%= link_to "Watching", library_index_path(status: :watching), class: "px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap #{params[:status] == 'watching' ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
    <%= link_to "Finished", library_index_path(status: :finished), class: "px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap #{params[:status] == 'finished' ? 'bg-sv-accent text-white' : 'bg-sv-surface text-sv-text-muted hover:text-white'}" %>
  </div>

  <%# Result count and page size %>
  <% if @entries.any? %>
    <div class="flex items-center justify-between mb-4">
      <p class="text-sm text-sv-text-muted">
        Showing <%= (@page - 1) * @per_page + 1 %>&ndash;<%= [@page * @per_page, @total].min %> of <%= @total %>
      </p>
      <div class="flex items-center gap-1">
        <% [25, 50, 100].each do |size| %>
          <% if size == @per_page %>
            <span class="px-2 py-1 rounded bg-sv-accent text-white text-xs font-medium"><%= size %></span>
          <% else %>
            <%= link_to size, library_index_path(params.permit(:type, :status).merge(per_page: size, page: 1)), class: "px-2 py-1 rounded bg-sv-surface text-sv-text-muted hover:text-white text-xs transition-colors" %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @entries.any? %>
    <div class="flex gap-4 overflow-x-auto scrollbar-hide pb-2">
      <% @entries.each do |entry| %>
        <div class="poster-card group shrink-0" style="width: 160px">
          <%= link_to content_path(type: entry.content_type, imdb_id: entry.imdb_id) do %>
            <% if entry.poster_url %>
              <img src="<%= entry.poster_url %>" alt="<%= entry.title %>" loading="lazy" class="w-full aspect-[2/3] object-cover">
            <% else %>
              <div class="w-full aspect-[2/3] bg-sv-surface flex items-center justify-center">
                <svg class="w-12 h-12 text-sv-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
              </div>
            <% end %>
            <div class="p-2">
              <h3 class="text-xs font-medium text-white truncate"><%= entry.title %></h3>
              <p class="text-xs text-sv-text-muted mt-0.5"><%= entry.year %></p>
              <span class="badge badge-accent text-xs mt-1"><%= entry.watch_status.humanize %></span>
            </div>
            <% progress = @progress_map&.dig(entry.imdb_id) %>
            <% if progress&.max_progress&.to_i&.positive? %>
              <div class="card-progress">
                <div class="card-progress-bar" style="width: <%= progress.max_progress.to_i %>%"></div>
              </div>
            <% end %>
          <% end %>
          <div class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <%= button_to library_path(entry), method: :delete, class: "w-7 h-7 bg-black/60 rounded-full flex items-center justify-center text-white hover:bg-red-600", data: { turbo_confirm: "Remove from library?" } do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Pagination %>
    <% if @total_pages > 1 %>
      <nav class="flex items-center justify-center gap-2 mt-8" aria-label="Library pagination">
        <% if @page > 1 %>
          <%= link_to "&larr; Previous".html_safe, library_index_path(params.permit(:type, :status).merge(page: @page - 1, per_page: @per_page)), class: "px-3 py-2 rounded-lg bg-sv-surface text-sv-text hover:bg-sv-surface-hover transition-colors text-sm" %>
        <% end %>

        <%
          visible_pages = []
          visible_pages << 1 unless @total_pages <= 1
          ([@page - 2, 2].max..[@page + 2, @total_pages - 1].min).each { |p| visible_pages << p }
          visible_pages << @total_pages if @total_pages > 1
          visible_pages = visible_pages.uniq.sort
        %>
        <% prev_page = 0 %>
        <% visible_pages.each do |p| %>
          <% if p - prev_page > 1 %>
            <span class="px-2 text-sv-text-muted">&hellip;</span>
          <% end %>
          <% if p == @page %>
            <span class="px-3 py-2 rounded-lg bg-sv-accent text-white text-sm font-medium"><%= p %></span>
          <% else %>
            <%= link_to p, library_index_path(params.permit(:type, :status).merge(page: p, per_page: @per_page)), class: "px-3 py-2 rounded-lg bg-sv-surface text-sv-text hover:bg-sv-surface-hover transition-colors text-sm" %>
          <% end %>
          <% prev_page = p %>
        <% end %>

        <% if @page < @total_pages %>
          <%= link_to "Next &rarr;".html_safe, library_index_path(params.permit(:type, :status).merge(page: @page + 1, per_page: @per_page)), class: "px-3 py-2 rounded-lg bg-sv-surface text-sv-text hover:bg-sv-surface-hover transition-colors text-sm" %>
        <% end %>
      </nav>
    <% end %>
  <% else %>
    <div class="text-center py-16">
      <svg class="w-16 h-16 text-sv-text-muted mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      <p class="text-sv-text-muted mb-4">Your library is empty.</p>
      <%= link_to "Search for content", search_index_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>

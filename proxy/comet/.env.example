# Comet configuration
#
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#   docker compose up -d

# Admin dashboard password.  Required — if blank, Comet generates a
# random one at startup and logs it.
ADMIN_DASHBOARD_PASSWORD=change-me-now

# Optional: protect the /configure page with a password.
# Leave blank to allow open access from the VPS/Tailscale.
# CONFIGURE_PAGE_PASSWORD=

# Database (internal to Comet — not shared with StreamVault).
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://comet:comet@comet-postgres:5432/comet

# ── Scraper configuration ─────────────────────────────────────────
# Comet disables ALL scrapers by default.  You must enable at least
# one, otherwise Comet returns zero streams for everything.
#
# The Torrentio scraper reuses the same public Torrentio API that
# StreamVault already uses — it's the simplest option and needs no
# extra services.  If your VPS IP is Cloudflare-blocked, set the
# proxy below.
SCRAPE_TORRENTIO=True
TORRENTIO_URL=https://torrentio.strem.fun

# Optional: route Torrentio scraping through the Tinyproxy if the
# VPS IP is Cloudflare-blocked.  Uses the same Tinyproxy instance
# already running for StreamVault's Torrentio proxy.
# TORRENTIO_PROXY_URL=http://100.x.x.x:8888

# Jackett (requires a running Jackett instance)
# SCRAPE_JACKETT=both
# JACKETT_URL=http://jackett:9117
# JACKETT_API_KEY=your_jackett_api_key

# Zilean (DMM hashlist ingester — broadens search coverage)
# SCRAPE_ZILEAN=live
# ZILEAN_URL=http://zilean:8181

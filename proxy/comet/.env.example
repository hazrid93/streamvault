# Comet configuration
#
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#   docker compose up -d
#
# After first start, get the Jackett API key and add it here, then restart:
#   docker compose exec jackett bash -c "cat /config/Jackett/ServerConfig.json | jq -r .APIKey"

# Admin dashboard password. Required — if blank, Comet generates a
# random one at startup and logs it.
ADMIN_DASHBOARD_PASSWORD=change-me-now

# Optional: protect the /configure page with a password.
# CONFIGURE_PAGE_PASSWORD=

# Database (internal to Comet — not shared with StreamVault).
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://comet:comet@comet-postgres:5432/comet

# ── Scrapers (independent of Torrentio) ───────────────────────────
# Comet uses its own scrapers, NOT the Torrentio API. This makes it
# a truly independent alternative — Torrentio downtime/Cloudflare
# blocks don't affect Comet.

# Jackett — self-hosted torrent indexer aggregator.
# Scrapes torrent sites directly (1337x, TPB, etc.).
# You MUST set the API key after first start (see comment above).
# Scraper mode: live = scrape on request, both = live + background.
SCRAPE_JACKETT=live
JACKETT_API_KEY=

# Zilean — DMM hashlist index. Uses pre-computed torrent hashes.
# The public instance works out of the box (no setup needed).
# Scraper mode: live = scrape on request, both = live + background.
SCRAPE_ZILEAN=live
ZILEAN_URL=https://zileanfortheweebs.midnightignite.me

# Disable anime mapping — it downloads three external JSON files at
# startup and can hang if the VPS can't reach those APIs, blocking
# Comet from serving any requests. Only needed for anime content.
ANIME_MAPPING_ENABLED=False

# ── Background scraper (optional) ─────────────────────────────────
# Pre-caches popular content so searches resolve instantly.
# Increases RAM/CPU usage but eliminates first-request delays.
# BACKGROUND_SCRAPER_ENABLED=True
# BACKGROUND_SCRAPER_CONCURRENT_WORKERS=1

# ── PUID/PGID for Jackett ──────────────────────────────────────────
# PUID=1000
# PGID=1000
# TZ=Europe/London

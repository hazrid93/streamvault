# Comet configuration
#
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#   docker compose up -d

# Admin dashboard password.  Required — if blank, Comet generates a
# random one at startup and logs it.
ADMIN_DASHBOARD_PASSWORD=change-me-now

# Optional: protect the /configure page with a password.
# Leave blank to allow open access from the VPS/Tailscale.
# CONFIGURE_PAGE_PASSWORD=

# Database (internal to Comet — not shared with StreamVault).
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://comet:comet@comet-postgres:5432/comet

# ── Scraper configuration (optional) ──────────────────────────────
# Comet supports multiple scrapers.  The built-in Torrentio scraper
# is enabled by default.  Uncomment to add more:

# Jackett (requires a running Jackett instance)
# SCRAPE_JACKETT=True
# JACKETT_URL=http://jackett:9117
# JACKETT_API_KEY=your_jackett_api_key

# Zilean (DMM hashlist ingester)
# SCRAPE_ZILEAN=False
# ZILEAN_URL=http://zilean:8181

# ── Debrid proxy (optional) ───────────────────────────────────────
# If the VPS IP is blocked by RealDebrid, route Comet's RD requests
# through the Tinyproxy (same proxy used for Torrentio).
# DEBRID_PROXY=http://tinyproxy:8888

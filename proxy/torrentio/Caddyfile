# Caddy auto-provisions Let's Encrypt certs for the domain.
# The TORRENTIO_DOMAIN env var replaces {$TORRENTIO_DOMAIN} below.
#
# For HTTP-only testing (no domain), use the compose default profile:
#   docker compose up --build -d
# The proxy listens on port 3000 directly.
#
# For HTTPS with a domain:
#   export TORRENTIO_DOMAIN=torrentio.yourdomain.com
#   docker compose --profile https up --build -d

{$TORRENTIO_DOMAIN} {
	reverse_proxy torrentio-proxy:3000
}

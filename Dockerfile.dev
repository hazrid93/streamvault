# Development Dockerfile — includes build tools, ffmpeg, and runs as root
# for live editing via volume mounts. Not for production.

ARG RUBY_VERSION=4.0.5
FROM docker.io/library/ruby:$RUBY_VERSION-slim

WORKDIR /rails

# Install system dependencies:
# - build-essential, git, pkg-config, libyaml-dev: for gem compilation
# - ffmpeg: for stream transcoding
# - libvips: for image processing (Active Storage)
# - libjemalloc2: for memory efficiency
# - nodejs: required by tailwindcss:watch
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential git pkg-config libyaml-dev \
      ffmpeg libvips libjemalloc2 \
      nodejs && \
    ln -s /usr/lib/$(uname -m)-linux-gnu/libjemalloc.so.2 /usr/local/lib/libjemalloc.so && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

ENV RAILS_ENV="development" \
    BUNDLE_PATH="/usr/local/bundle" \
    BUNDLE_WITHOUT="production" \
    LD_PRELOAD="/usr/local/lib/libjemalloc.so"

# Install gems
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy application code (also mounted as volume for live editing)
COPY . .

# Run as root for dev so volume permissions work seamlessly
EXPOSE 3000

# Entrypoint prepares the database on server start
ENTRYPOINT ["/rails/bin/docker-entrypoint"]

# Local production-like Dockerfile — builds assets in the image so they
# don't interfere with local development files. Run with docker-compose.yml.

ARG RUBY_VERSION=4.0.5
FROM docker.io/library/ruby:$RUBY_VERSION-slim

WORKDIR /rails

# Install system dependencies:
# - build-essential, git, pkg-config, libyaml-dev: for gem compilation
# - ffmpeg: for stream transcoding
# - libvips: for image processing (Active Storage)
# - libjemalloc2: for memory efficiency
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential git pkg-config libyaml-dev \
      ffmpeg libvips libjemalloc2 && \
    ln -s /usr/lib/$(uname -m)-linux-gnu/libjemalloc.so.2 /usr/local/lib/libjemalloc.so && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

ENV RAILS_ENV="production" \
    BUNDLE_DEPLOYMENT="1" \
    BUNDLE_PATH="/usr/local/bundle" \
    BUNDLE_WITHOUT="development test" \
    LD_PRELOAD="/usr/local/lib/libjemalloc.so"

# Install gems
COPY Gemfile Gemfile.lock ./
RUN bundle install && \
    rm -rf ~/.bundle/ "${BUNDLE_PATH}"/ruby/*/cache

# Copy application code
COPY . .

# Precompile assets in the image (no RAILS_MASTER_KEY needed for precompile).
# This builds tailwind.css + application.css into public/assets with digests.
# The local development assets in app/assets/builds and public/assets are
# NOT mounted into the container (see docker-compose.yml volume), so the
# precompiled production assets are used instead.
RUN SECRET_KEY_BASE_DUMMY=1 ./bin/rails assets:precompile && \
    rm -rf /rails/tmp/*

EXPOSE 3000

ENTRYPOINT ["/rails/bin/docker-entrypoint"]
CMD ["./bin/thrust", "./bin/rails", "server"]

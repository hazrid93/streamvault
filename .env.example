# StreamVault environment configuration
#
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#   docker compose up -d --build

# ── Rails secrets ────────────────────────────────────────────────
# Master key for decrypting config/credentials.yml.enc.
# Use the value from config/master.key in the repo.
RAILS_MASTER_KEY=

# Secret key base for session cookies. Generate with:
#   docker compose run --rm web bin/rails secret
SECRET_KEY_BASE=

# ── Active Record Encryption ─────────────────────────────────────
# 32-char hex strings. Generate with:
#   openssl rand -hex 32
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ── App configuration ────────────────────────────────────────────
# Domain the app is served from (used for Rails host authorization).
APP_DOMAIN=

# ── Database (Postgres) ──────────────────────────────────────────
# Credentials for the Postgres container. Set POSTGRES_PASSWORD to
# a strong value (generate with: openssl rand -hex 16).
POSTGRES_USER=streamvault
POSTGRES_PASSWORD=
POSTGRES_DB=streamvault

# Host port to expose the app on (container always listens on 80).
PORT=3000

# ── External APIs ────────────────────────────────────────────────
# Torrentio API base URL. Default is the public instance, but it may
# be blocked by Cloudflare. Consider running a self-hosted proxy
# (see torrentio-proxy/ directory).
TORRENTIO_API_BASE_URL=https://torrentio.strem.fun

# RealDebrid API base URL.
REALDEBRID_API_BASE_URL=https://api.real-debrid.com/rest/1.0

# OMDB API key for ratings metadata. Get one at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# SubDL API key for external subtitle fallback. Get one at https://subdl.com/panel/api
SUBDL_API_KEY=

# StreamVault environment configuration
#
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#   docker compose up -d --build

# ── Rails secrets ────────────────────────────────────────────────
# Master key for decrypting config/credentials.yml.enc.
# Use the value from config/master.key in the repo.
RAILS_MASTER_KEY=

# Secret key base for session cookies. Generate with:
#   docker compose run --rm web bin/rails secret
SECRET_KEY_BASE=

# ── Active Record Encryption ─────────────────────────────────────
# 32-char hex strings. Generate with:
#   openssl rand -hex 32
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ── App configuration ────────────────────────────────────────────
# Domain the app is served from (used for Rails host authorization).
APP_DOMAIN=

# ── Signups ──────────────────────────────────────────────────────
# Whether new users can self-register. Disabled by default for security.
# Set to "true" to enable the signup page. When disabled, create users
# via Rails console (see README).
ENABLE_SIGNUPS=false

# ── Database (Postgres) ──────────────────────────────────────────
# Credentials for the Postgres container. Set POSTGRES_PASSWORD to
# a strong value (generate with: openssl rand -hex 16).
POSTGRES_USER=streamvault
POSTGRES_PASSWORD=
POSTGRES_DB=streamvault

# Host port to expose the app on (container always listens on 80).
PORT=3000

# ── External APIs ────────────────────────────────────────────────
# Torrentio API base URL. Default is the public instance, but it may
# be blocked by Cloudflare. Consider running a self-hosted proxy
# (see torrentio-proxy/ directory).
TORRENTIO_API_BASE_URL=https://torrentio.strem.fun

# ── Stream Provider ───────────────────────────────────────────────
# Which addon to use for stream listings and resolution.
#   torrentio → Torrentio only (default, backward-compatible)
#   comet     → Comet primary, Torrentio fallback
#   auto      → Comet if COMET_URL is set, else Torrentio; Comet first
#               with Torrentio fallback when both are configured
# Self-host Comet for maximum stability (no Cloudflare blocks, no rate
# limits, no peak-hour congestion). See proxy/comet/ for docker setup.
STREAM_PROVIDER=torrentio

# Comet addon URL. Set to your self-hosted Comet instance
# (e.g. http://<vps-tailscale-ip>:8000 or https://comet.example.com).
# Leave blank to disable Comet.
# COMET_URL=http://100.x.x.x:8000

# Forward proxy for Comet requests. Set if Comet needs a proxy to reach
# torrent indexers or RealDebrid. Usually blank (Comet runs on the VPS
# which has direct access). Leave commented to connect directly.
# COMET_PROXY=http://<vps-ip>:8888

# Forward proxy for torrentio requests. Set to the Tinyproxy address
# (see proxy/torrentio/ directory) if torrentio is blocked by Cloudflare
# from your server. Leave commented to connect directly.
# TORRENTIO_PROXY=http://<vps-ip>:8888

# Forward proxy for Cinemeta metadata requests (popular/trending,
# search, episode lists). Cinemeta is NOT behind the same Cloudflare
# WAF as torrentio and usually works directly. Set this only if your
# network blocks cinemeta too. Leave commented to connect directly.
# CINEMETA_PROXY=http://<vps-ip>:8888

# RealDebrid API base URL.
REALDEBRID_API_BASE_URL=https://api.real-debrid.com/rest/1.0

# OMDB API key for ratings metadata. Get one at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# TMDB Read Access Token (v4 bearer token) for "Recommended for You"
# on the home page. Get one at https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=

# SubDL API key for external subtitle fallback. Get one at https://subdl.com/panel/api
SUBDL_API_KEY=
